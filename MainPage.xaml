<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="ColorFallPuzzle.MainPage">

    <Grid Padding="20" RowDefinitions="Auto,*,Auto" ColumnDefinitions="*">
        <Label x:Name="ScoreLabel"
               Text="Score: 0"
               FontSize="24"
               HorizontalOptions="Center"
               Grid.Row="0" />

        <skia:SKCanvasView x:Name="GameCanvas"
                           PaintSurface="OnCanvasPaint"
                           HorizontalOptions="Fill"
                           VerticalOptions="FillAndExpand"
                           Grid.Row="1" />

        <!-- Android için kod tarafında BannerAd ekleniyor -->
        <Grid x:Name="BannerHost"
              HeightRequest="50"
              MinimumHeightRequest="50"
              HorizontalOptions="Fill"
              VerticalOptions="End"
              Grid.Row="2" />
    </Grid>

</ContentPage>
